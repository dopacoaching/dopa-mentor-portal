# ─── Database ─────────────────────────────────────────────────────────────────
# MongoDB connection string (required — app will not boot without it).
MONGODB_URI=mongodb+srv://<user>:<password>@<cluster>.mongodb.net/dopa-mentor-portal

# ─── Auth ─────────────────────────────────────────────────────────────────────
# Secret used to sign JWTs (required). Use a long random string.
JWT_SECRET=replace-with-a-long-random-string
# Optional — token lifetime. Defaults to 7d if unset.
JWT_EXPIRES_IN=7d

# ─── Cron protection ──────────────────────────────────────────────────────────
# Shared secret Vercel sends as `Authorization: Bearer <CRON_SECRET>` to cron
# routes. Required in production or the daily jobs return 401.
CRON_SECRET=replace-with-a-long-random-string

# ─── Cloudinary (chat image / voice uploads) ──────────────────────────────────
CLOUDINARY_CLOUD_NAME=your-cloud-name
CLOUDINARY_API_KEY=your-api-key
CLOUDINARY_API_SECRET=your-api-secret

# ─── App ──────────────────────────────────────────────────────────────────────
# Public base URL, used for server-actions allowed origins.
NEXT_PUBLIC_APP_URL=https://your-app.vercel.app

# ─── Seed script only (scripts/seed.ts) ───────────────────────────────────────
# Used once to create the initial admin account. Not needed at runtime.
ADMIN_USERNAME=admin
ADMIN_PASSWORD=replace-with-a-strong-password
